# Copy to .env and fill in values

# development | production | test
ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://aidevconnect:aidevconnect@db:5432/aidevconnect
# Production: use Neon pgvector URL — see docs/DATABASE.md
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
# Gemini API Studio key — https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Optional — only if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
MOCK_EMBEDDINGS=true
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Comma-separated browser origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional — defaults shown
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIMENSIONS=1536
# MATCH_MIN_SIMILARITY=0.72
